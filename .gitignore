# RideLog .gitignore

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.eggs/
eggs/
*.egg-info/
*.egg
.installed.cfg
wheels/
downloads/
parts/
sdist/
.coverage
htmlcov/
coverage.xml

# ── Virtualenv ───────────────────────────────────────────────────────────────
.venv
env/
venv/
ENV/

# ── Node / npm ───────────────────────────────────────────────────────────────
node_modules/
frontend/.cache/

# ── Build outputs ────────────────────────────────────────────────────────────
build/
dist/
frontend/dist/
frontend/build/

# ── Base de données et données persistantes ───────────────────────────────────
/data/
*.db
*.sqlite3
*.sqlite

# ── Configuration sensible ────────────────────────────────────────────────────
# .env contient les secrets (JWT_SECRET, HA_INIT_KEY, etc.) — ne jamais commiter
.env
secrets.env
# IMPORTANT : .env.example est versionné intentionnellement (valeurs fictives)
# La ligne .env ci-dessus ne l'exclut pas car elle correspond uniquement à ".env" exact

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.orig

# ── Docker ───────────────────────────────────────────────────────────────────
*.pid
*.sock

# ── Éditeurs ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# ── Fichiers temporaires ─────────────────────────────────────────────────────
*.bak
*.old
*.swp
*~

# ── Exports ──────────────────────────────────────────────────────────────────
*.zip

# ── Home Assistant ───────────────────────────────────────────────────────────
ha-integration/custom_components/ridelog/__pycache__/