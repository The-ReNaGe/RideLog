# ════════════════════════════════════════════════════════════════════════════
# RideLog — Configuration
# ════════════════════════════════════════════════════════════════════════════
#
# 1. Copiez ce fichier en .env :
#       cp .env.example .env
#
# 2. Remplissez les valeurs marquées ⚠️  (obligatoires en production)
#
# 3. Le fichier .env est dans .gitignore — il ne sera jamais commité
#    Ce fichier .env.example est lui versionné et doit rester avec des
#    valeurs d'exemple uniquement (jamais vos vraies clés)
#
# ════════════════════════════════════════════════════════════════════════════


# ── AUTHENTIFICATION & SÉCURITÉ ─────────────────────────────────────────────

# ⚠️  Clé secrète pour signer les tokens JWT — OBLIGATOIRE
# Toute modification invalide toutes les sessions actives (déconnexion de tous)
# Générer une clé forte :  openssl rand -hex 32
JWT_SECRET=changez-moi-en-production

# ⚠️  Clé secrète pour l'initialisation du compte Home Assistant
# Home Assistant doit fournir cette clé pour créer son compte d'intégration
# Peut être n'importe quelle chaîne — mais choisissez quelque chose de robuste
# Générer :  openssl rand -hex 16
HA_INIT_KEY=changez-moi-aussi


# ── INSCRIPTION ─────────────────────────────────────────────────────────────

# Mode d'inscription des nouveaux utilisateurs :
#   invite  → sur invitation uniquement — un admin génère un lien (recommandé)
#   open    → inscription libre, tout le monde peut créer un compte
#   closed  → fermé, seul un admin peut créer des comptes manuellement
REGISTRATION_MODE=invite


# ── LOGS & CORS ─────────────────────────────────────────────────────────────

# Niveau de log : DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Origines autorisées pour les requêtes CORS (séparées par des virgules)
# En production, remplacer * par votre domaine :
#   CORS_ORIGINS=https://ridelog.votredomaine.com
CORS_ORIGINS=*


# ── APIS OPTIONNELLES ───────────────────────────────────────────────────────

# Décodage de plaque d'immatriculation française (10 req/mois gratuit)
# Sans cette clé, le bouton "Décoder la plaque" sera désactivé
# Obtenir une clé : https://rapidapi.com/api-plaque-immatriculation-siv-api-plaque-immatriculation-siv-default/api/api-plaque-immatriculation-siv/
# Le décodage VIN utilise l'API NHTSA — gratuit, sans clé nécessaire
RAPIDAPI_KEY=


# ── RAPPELS / SCHEDULER ─────────────────────────────────────────────────────

# Intervalle de vérification des rappels en secondes
# 3600 = toutes les heures (recommandé)
REMINDER_INTERVAL=3600

# Activer ou désactiver le scheduler de rappels automatiques
REMINDER_ENABLED=true